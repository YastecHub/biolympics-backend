# Backend-only env (the root .env.example is the source of truth for compose).
APP_ENV=development
APP_NAME=BIOLYMPICS LIVE
APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
SECRET_KEY=change-me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
# Local Postgres, or a managed Supabase URL (postgresql+asyncpg://..., keep
# ?sslmode=require for Supabase). SQLite (sqlite+aiosqlite:///./biolympics_dev.db)
# also works for offline dev.
DATABASE_URL=postgresql+asyncpg://biolympics:biolympics@localhost:5432/biolympics
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CORS_ORIGINS=http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@biolympics.example
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=biolympics
S3_SECRET_KEY=biolympics-secret
S3_BUCKET=biolympics-media
S3_REGION=us-east-1
INITIAL_ADMIN_EMAIL=admin@biolympics.ng
INITIAL_ADMIN_PASSWORD=ChangeMe!2026
SENTRY_DSN=
